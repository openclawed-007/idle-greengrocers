---
import { withBase } from '@lib/paths';
import { site } from '@lib/site';
import { navLeft, navRight } from '@lib/nav';
import Wordmark from '@components/Wordmark.astro';

const year = new Date().getFullYear();

// Pre-fills a WhatsApp message asking to join the weekly list. The link
// opens the user's own WhatsApp conversation with us — no account
// needed, nothing to store server-side.
const waJoinMessage = encodeURIComponent(
  "Hi Idle Greengrocers — please add me to your weekly WhatsApp list for what's in this week.",
);
const waJoinHref = `https://wa.me/${site.whatsapp.number.replace(/\D/g, '')}?text=${waJoinMessage}`;
---

<footer class="footer-shell green-texture text-cream">
  <div class="container-wide section grid grid-cols-2 gap-x-8 gap-y-10 py-16 md:grid-cols-12 md:gap-12">
    <div class="col-span-2 md:col-span-4 flex flex-col items-start gap-6 text-left">
      <Wordmark tone="cream" size="md" showEst={false} />
      <p class="max-w-prose2 text-sm text-cream/80">
        A family-run greengrocer in the heart of Idle village, sourcing the best fruit, vegetables
        and local produce from across Yorkshire.
      </p>
      <div class="flex items-center justify-center gap-4">
        <a href={site.socials.instagram} class="text-cream/80 hover:text-cream" aria-label="Instagram" rel="me noopener">
          <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.4">
            <rect x="3" y="3" width="18" height="18" rx="5" />
            <circle cx="12" cy="12" r="4" />
            <circle cx="17.5" cy="6.5" r="1" fill="currentColor" />
          </svg>
        </a>
        <a href={site.socials.facebook} class="text-cream/80 hover:text-cream" aria-label="Facebook" rel="me noopener">
          <svg viewBox="0 0 24 24" class="h-5 w-5" fill="currentColor">
            <path d="M13 22v-8h3l.5-4H13V7.5c0-1.1.3-1.8 1.9-1.8H17V2.1C16.6 2 15.4 2 14 2c-3 0-5 1.8-5 5.2V10H6v4h3v8h4z" />
          </svg>
        </a>
      </div>
    </div>

    <div class="col-span-1 md:col-span-2">
      <h4 class="eyebrow-dark mb-4">Shop</h4>
      <ul class="space-y-2 text-sm">
        {navLeft.map((item) => (
          <li><a href={withBase(item.href)} class="text-cream/80 hover:text-cream">{item.label}</a></li>
        ))}
      </ul>
    </div>

    <div class="col-span-1 md:col-span-2">
      <h4 class="eyebrow-dark mb-4">Info</h4>
      <ul class="space-y-2 text-sm">
        {navRight.map((item) => (
          <li><a href={withBase(item.href)} class="text-cream/80 hover:text-cream">{item.label}</a></li>
        ))}
      </ul>
    </div>

    <div class="col-span-2 md:col-span-4">
      <h4 class="eyebrow-dark mb-4">Visit</h4>
      <address class="not-italic text-sm text-cream/80">
        {site.address.line1}<br />
        {site.address.locality}, {site.address.postalCode}<br />
        {site.address.region}
      </address>
      <p class="mt-3 text-sm text-cream/80">
        <a href={`tel:${site.contact.phone.replace(/\s/g, '')}`} class="hover:text-cream">{site.contact.phoneDisplay}</a><br />
        <a href={`mailto:${site.contact.email}`} class="hover:text-cream">{site.contact.email}</a>
      </p>
    </div>

    <!-- Weekly WhatsApp list — one-tap join, no accounts, no inbox. -->
    <div class="col-span-2 md:col-span-12">
      <div class="footer-whatsapp">
        <div>
          <p class="eyebrow-dark">What's in this week</p>
          <p class="footer-whatsapp__line">
            Join the weekly WhatsApp list for a short note every Friday — what's landing, what's leaving, and the odd recipe idea. Message us and we'll add you.
          </p>
        </div>
        <a
          href={waJoinHref}
          target="_blank"
          rel="noopener"
          class="footer-whatsapp__button"
        >
          <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M21 11.5a8.38 8.38 0 0 1-8.5 8.5 8.5 8.5 0 0 1-7.6-4.9L3 21l5.9-2.1A8.38 8.38 0 0 1 3 12.5 8.5 8.5 0 0 1 12.5 4a8.38 8.38 0 0 1 8.5 7.5" />
          </svg>
          Join the list
        </a>
      </div>
    </div>
  </div>

  <div class="border-t border-cream/10">
    <div class="container-wide section flex flex-col items-start justify-between gap-2 py-6 text-xs text-cream/60 md:flex-row md:items-center">
      <p>&copy; {year} {site.name}. All rights reserved.</p>
      <p>Made with care in {site.address.locality}, Yorkshire.</p>
    </div>
  </div>
</footer>

<style>
  .footer-whatsapp {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    align-items: flex-start;
    border-top: 1px solid rgba(245, 239, 227, 0.12);
    padding-top: 1.5rem;
  }

  .footer-whatsapp__line {
    margin-top: 0.55rem;
    max-width: 54ch;
    font-size: 0.88rem;
    line-height: 1.55;
    color: rgba(245, 239, 227, 0.75);
  }

  .footer-whatsapp__button {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.75rem 1.25rem;
    border: 1px solid rgba(245, 239, 227, 0.4);
    color: #F5EFE3;
    font-family: Inter, system-ui, sans-serif;
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    transition: background-color 150ms ease, border-color 150ms ease;
    white-space: nowrap;
  }

  .footer-whatsapp__button:hover,
  .footer-whatsapp__button:focus-visible {
    background: rgba(245, 239, 227, 0.08);
    border-color: rgba(245, 239, 227, 0.7);
  }

  @media (min-width: 768px) {
    .footer-whatsapp {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      gap: 2rem;
    }
  }
</style>
