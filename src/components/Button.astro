---
import { withBase } from '@lib/paths';

type Props = {
  href?: string;
  variant?: 'primary' | 'outline' | 'outline-cream';
  type?: 'button' | 'submit' | 'reset';
  class?: string;
  ariaLabel?: string;
};
const {
  href,
  variant = 'primary',
  type = 'button',
  class: className = '',
  ariaLabel,
} = Astro.props;

const classes = {
  primary: 'btn-primary',
  outline: 'btn-outline',
  'outline-cream': 'btn-outline-cream',
}[variant];

const Tag = href ? 'a' : 'button';
const resolvedHref = href ? withBase(href) : undefined;
---

<Tag
  class={`${classes} ${className}`}
  href={resolvedHref}
  type={href ? undefined : type}
  aria-label={ariaLabel}
>
  <slot />
</Tag>
