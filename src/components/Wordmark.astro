---
/**
 * Centered editorial wordmark used in the header and footer.
 * Accepts `tone` to switch between dark-on-cream and cream-on-dark.
 */
type Props = {
  tone?: 'dark' | 'cream';
  showEst?: boolean;
  size?: 'sm' | 'md' | 'lg';
  class?: string;
};
const { tone = 'dark', showEst = true, size = 'md', class: className = '' } = Astro.props;

const color = tone === 'dark' ? 'text-forest-ink' : 'text-cream';
const rule = tone === 'dark' ? 'bg-forest-ink/70' : 'bg-cream/70';
const sizes = {
  sm: { row: 'text-xl', tracking: 'tracking-[0.22em]' },
  md: { row: 'text-2xl md:text-[1.6rem]', tracking: 'tracking-[0.28em]' },
  lg: { row: 'text-3xl md:text-4xl', tracking: 'tracking-[0.32em]' },
}[size];
---

<a href="/" class={`inline-flex flex-col items-center ${color} ${className}`} aria-label="Idle Greengrocers — home">
  <!-- Laurel mark -->
  <svg
    aria-hidden="true"
    viewBox="0 0 64 28"
    class="mb-1 h-5 w-16"
    fill="none"
    stroke="currentColor"
    stroke-width="1.2"
    stroke-linecap="round"
  >
    <path d="M32 3 v22" />
    <path d="M32 8 c-6 -1 -11 -2 -14 -5" />
    <path d="M32 13 c-7 -1 -13 -3 -17 -6" />
    <path d="M32 18 c-6 -1 -11 -2 -14 -4" />
    <path d="M32 8 c6 -1 11 -2 14 -5" />
    <path d="M32 13 c7 -1 13 -3 17 -6" />
    <path d="M32 18 c6 -1 11 -2 14 -4" />
  </svg>

  <span class={`font-display font-medium leading-none ${sizes.row} ${sizes.tracking}`}>IDLE</span>

  <span class={`my-1 block h-px w-8 ${rule}`} aria-hidden="true"></span>

  <span class={`font-display font-medium leading-none ${sizes.row} ${sizes.tracking}`}>
    GREENGROCERS
  </span>

  {showEst && (
    <span class="mt-2 font-sans text-[0.58rem] font-medium uppercase tracking-widest2 opacity-80">
      EST. 2020
    </span>
  )}
</a>
