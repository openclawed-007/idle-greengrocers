---
import { navLeft, navRight } from '@lib/nav';
import { stripBase, withBase } from '@lib/paths';
import Wordmark from '@components/Wordmark.astro';

const currentPath = stripBase(Astro.url.pathname).replace(/\/$/, '') || '/';

function isActive(href: string) {
  if (href === '/') return currentPath === '/';
  return currentPath === href || currentPath.startsWith(href + '/');
}
---

<header class="site-header relative z-40 border-b border-ink/5 bg-cream" data-site-header>
  <a href="#main" class="skip-link">Skip to content</a>

  <div class="container-wide section relative flex items-center justify-center gap-6 py-6 md:py-7 lg:justify-between">
    <!-- Mobile / tablet: hamburger / close (visible below lg) -->
    <button
      type="button"
      class="mobile-toggle absolute left-0 top-1/2 inline-flex -translate-y-1/2 items-center justify-center rounded p-2 text-ink lg:hidden"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="mobile-nav"
      data-mobile-toggle
    >
      <svg viewBox="0 0 24 24" class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" aria-hidden="true">
        <!-- Three lines that morph into an X when [aria-expanded=true] -->
        <path class="line line-top"    d="M4 7h16" />
        <path class="line line-middle" d="M4 12h16" />
        <path class="line line-bottom" d="M4 17h16" />
      </svg>
    </button>

    <!-- Desktop primary nav (≥ lg). Single landmark containing the
         wordmark home-link + left/right link groups, so SR users hear
         exactly one 'Primary' navigation. -->
    <nav aria-label="Primary" class="hidden w-full flex-1 items-center justify-between gap-6 lg:flex">
      <ul class="flex items-center gap-8">
        {navLeft.map((item) => (
          <li>
            <a
              href={withBase(item.href)}
              class={`nav-link ${isActive(item.href) ? 'is-active' : ''}`}
              aria-current={isActive(item.href) ? 'page' : undefined}
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
      <Wordmark size="md" />
      <ul class="flex items-center gap-8">
        {navRight.map((item) => (
          <li>
            <a
              href={withBase(item.href)}
              class={`nav-link ${isActive(item.href) ? 'is-active' : ''}`}
              aria-current={isActive(item.href) ? 'page' : undefined}
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <!-- Mobile / tablet: centred wordmark (below lg) -->
    <div class="flex justify-center lg:hidden">
      <Wordmark size="md" />
    </div>

  </div>

  <!-- Mobile: backdrop — overlays page content, closes the menu on click. -->
  <div class="mobile-backdrop lg:hidden" data-mobile-backdrop aria-hidden="true"></div>

  <!-- Mobile nav panel — absolutely positioned, doesn't push page content. -->
  <div
    id="mobile-nav"
    class="mobile-panel lg:hidden"
    data-mobile-panel
    aria-hidden="true"
    inert
  >
    <nav aria-label="Primary" class="mobile-drawer container-wide section">
      <div class="mobile-drawer__bar">
        <span>Menu</span>
        <button type="button" class="mobile-drawer__close" aria-label="Close menu" data-mobile-close>
          <svg viewBox="0 0 20 20" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" aria-hidden="true">
            <path d="M5 5 L15 15 M15 5 L5 15" />
          </svg>
        </button>
      </div>

      <a
        href={withBase('/our-produce')}
        class={`mobile-feature-link ${isActive('/our-produce') ? 'is-active' : ''}`}
        aria-current={isActive('/our-produce') ? 'page' : undefined}
        data-mobile-link
      >
        <span class="mobile-feature-link__icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 19c8.5-.2 13-5.7 14-14-8.1.9-13.7 5.4-14 14z" />
            <path d="M5 19c3.8-5 7.2-7.8 12-10" />
          </svg>
        </span>
        <span class="mobile-feature-link__copy">
          <span>Shop Produce</span>
          <small>Browse what is fresh today</small>
        </span>
        <svg viewBox="0 0 24 24" class="mobile-card-arrow" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" aria-hidden="true">
          <path d="M9 6l6 6-6 6" />
        </svg>
      </a>

      <div class="mobile-simple-list">
        {[
          { href: '/', label: 'Home', sub: 'Back to the front page' },
          { href: '/local-makers', label: 'Local Makers', sub: 'Meet our suppliers' },
          { href: '/about', label: 'About Us', sub: 'The shop story' },
          { href: '/delivery', label: 'Delivery', sub: 'Collection and local delivery' },
          { href: '/contact', label: 'Contact', sub: 'Visit, call or message us' },
        ].map((item) => (
          <a
            href={withBase(item.href)}
            class={`mobile-simple-link ${isActive(item.href) ? 'is-active' : ''}`}
            aria-current={isActive(item.href) ? 'page' : undefined}
            data-mobile-link
          >
            <span>
              <span>{item.label}</span>
              <small>{item.sub}</small>
            </span>
            <svg viewBox="0 0 24 24" class="mobile-card-arrow" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" aria-hidden="true">
              <path d="M9 6l6 6-6 6" />
            </svg>
          </a>
        ))}
      </div>
    </nav>
  </div>
</header>

<button
  type="button"
  class="scroll-menu-toggle lg:hidden"
  aria-label="Open menu"
  aria-expanded="false"
  aria-controls="mobile-nav"
  data-scroll-menu-toggle
  hidden
>
  <span class="scroll-menu-toggle__icon" aria-hidden="true">
    <span></span>
    <span></span>
    <span></span>
  </span>
  <span class="scroll-menu-toggle__text">Menu</span>
</button>

<style>
  /*
   * Hamburger ↔ X morph. We rotate the top/bottom lines into an X and
   * fade the middle line out when the button is expanded.
   */
  .mobile-toggle .line {
    transform-origin: center;
    transition: transform 200ms ease, opacity 150ms ease;
  }
  .mobile-toggle[aria-expanded='true'] .line-top {
    transform: translateY(5px) rotate(45deg);
  }
  .mobile-toggle[aria-expanded='true'] .line-middle {
    opacity: 0;
  }
  .mobile-toggle[aria-expanded='true'] .line-bottom {
    transform: translateY(-5px) rotate(-45deg);
  }

  /*
   * Backdrop: full-page dim beneath the mobile nav. Starts hidden,
   * fades in when the menu opens. Click to close.
   */
  .mobile-backdrop {
    position: fixed;
    inset: 0;
    z-index: 30;
    background: rgba(14, 36, 25, 0.28);
    backdrop-filter: blur(2px);
    opacity: 0;
    pointer-events: none;
    transition: opacity 200ms ease;
  }
  .mobile-backdrop[data-open] {
    opacity: 1;
    pointer-events: auto;
  }

  /*
   * Mobile nav panel: fixed to the top of the viewport so both the header
   * hamburger and floating scroll button open the same predictable drawer.
   */
  .mobile-panel {
    position: fixed;
    left: 0;
    right: 0;
    top: 0;
    z-index: 40;
    background: #F5EFE3;
    border-top: 1px solid rgba(28, 26, 22, 0.08);
    box-shadow: 0 16px 24px -12px rgba(14, 36, 25, 0.18);
    opacity: 0;
    transform: translateY(-8px);
    pointer-events: none;
    transition: opacity 200ms ease, transform 220ms ease;
    /* Scroll within the panel rather than clipping when the viewport
       (e.g. landscape phone) is shorter than the nav list. */
    max-height: 100dvh;
    overflow-y: auto;
    overscroll-behavior: contain;
  }
  .mobile-panel[data-open] {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  .mobile-drawer {
    display: grid;
    gap: 0.7rem;
    padding-top: 0.85rem;
    padding-bottom: 0.85rem;
  }

  .mobile-drawer__bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    min-height: 2.4rem;
    border-bottom: 1px solid rgba(28, 26, 22, 0.07);
    padding-bottom: 0.65rem;
    font-family: Inter, system-ui, sans-serif;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: rgba(14, 36, 25, 0.72);
  }

  .mobile-drawer__close {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 2.25rem;
    width: 2.25rem;
    border: 1px solid rgba(31, 58, 40, 0.12);
    color: #0E2419;
    transition: border-color 150ms ease, background-color 150ms ease;
  }

  .mobile-drawer__close:hover,
  .mobile-drawer__close:focus-visible {
    border-color: rgba(180, 71, 44, 0.38);
    background: rgba(251, 247, 238, 0.75);
  }

  .mobile-feature-link,
  .mobile-simple-link {
    position: relative;
    min-width: 0;
    color: #0E2419;
    transition: color 150ms ease, background-color 150ms ease, border-color 150ms ease;
  }

  .mobile-feature-link:hover,
  .mobile-feature-link:focus-visible,
  .mobile-simple-link:hover,
  .mobile-simple-link:focus-visible {
    background: rgba(251, 247, 238, 0.72);
  }

  .mobile-feature-link.is-active,
  .mobile-simple-link.is-active {
    border-color: rgba(180, 71, 44, 0.5);
    color: #B4472C;
  }

  .mobile-feature-link {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    align-items: center;
    gap: 0.85rem;
    padding: 0.9rem 1rem;
    border: 1px solid rgba(245, 239, 227, 0.18);
    background:
      linear-gradient(135deg, rgba(37, 54, 40, 0.98), rgba(14, 36, 25, 0.98)),
      #253628;
    color: #F5EFE3;
  }

  .mobile-feature-link:hover,
  .mobile-feature-link:focus-visible,
  .mobile-feature-link.is-active {
    background:
      linear-gradient(135deg, rgba(43, 74, 59, 0.98), rgba(14, 36, 25, 0.98)),
      #253628;
    color: #F5EFE3;
    border-color: rgba(245, 239, 227, 0.44);
  }

  .mobile-feature-link__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 2.55rem;
    width: 2.55rem;
    border-radius: 999px;
    background: rgba(245, 239, 227, 0.12);
  }

  .mobile-feature-link__copy,
  .mobile-simple-link > span {
    display: grid;
    gap: 0.1rem;
    min-width: 0;
  }

  .mobile-feature-link__copy > span,
  .mobile-simple-link > span > span {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 1.28rem;
    font-weight: 500;
    line-height: 1.05;
  }

  .mobile-feature-link small,
  .mobile-simple-link small {
    font-family: Inter, system-ui, sans-serif;
    font-size: 0.72rem;
    line-height: 1.35;
    color: currentColor;
    opacity: 0.7;
  }

  .mobile-simple-list {
    display: grid;
    border-top: 1px solid rgba(28, 26, 22, 0.07);
  }

  .mobile-card-arrow {
    height: 1.1rem;
    width: 1.1rem;
    opacity: 0.62;
  }

  .mobile-simple-link {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: center;
    gap: 0.8rem;
    padding: 0.85rem 0.2rem;
    border-bottom: 1px solid rgba(28, 26, 22, 0.07);
  }

  .mobile-simple-link.is-active {
    color: #B4472C;
  }

  .mobile-simple-link.is-active::before {
    content: '';
    position: absolute;
    left: -0.65rem;
    top: 50%;
    height: 1.1rem;
    width: 3px;
    background: #B4472C;
    transform: translateY(-50%);
    border-radius: 2px;
  }

  /* Lock body scroll while the menu is open (avoids background jump). */
  :global(body.mobile-nav-open) {
    overflow: hidden;
  }

  .scroll-menu-toggle {
    position: fixed;
    right: max(1rem, env(safe-area-inset-right));
    bottom: max(1rem, env(safe-area-inset-bottom));
    z-index: 35;
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    min-height: 3rem;
    padding: 0.7rem 1rem 0.7rem 0.78rem;
    border: 1px solid rgba(245, 239, 227, 0.34);
    background:
      linear-gradient(180deg, rgba(43, 74, 59, 0.96), rgba(14, 36, 25, 0.98));
    box-shadow:
      0 16px 30px -18px rgba(14, 36, 25, 0.72),
      0 1px 0 rgba(255, 255, 255, 0.12) inset;
    color: #F5EFE3;
    opacity: 0;
    pointer-events: none;
    transform: translateY(0.65rem) scale(0.98);
    transition: opacity 180ms ease, transform 200ms ease, border-color 150ms ease;
  }

  .scroll-menu-toggle[hidden] {
    display: none;
  }

  .scroll-menu-toggle[data-visible] {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0) scale(1);
  }

  .scroll-menu-toggle:hover,
  .scroll-menu-toggle:focus-visible {
    border-color: rgba(245, 239, 227, 0.72);
  }

  .scroll-menu-toggle__icon {
    position: relative;
    display: inline-flex;
    height: 1.65rem;
    width: 1.65rem;
    flex: none;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    background: rgba(245, 239, 227, 0.12);
  }

  .scroll-menu-toggle__icon span {
    position: absolute;
    left: 0.48rem;
    right: 0.48rem;
    height: 1px;
    background: currentColor;
  }

  .scroll-menu-toggle__icon span:nth-child(1) {
    transform: translateY(-0.28rem);
  }

  .scroll-menu-toggle__icon span:nth-child(3) {
    transform: translateY(0.28rem);
  }

  .scroll-menu-toggle__text {
    font-family: Inter, system-ui, sans-serif;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.24em;
    text-transform: uppercase;
  }

  @media (prefers-reduced-motion: reduce) {
    .scroll-menu-toggle,
    .mobile-panel {
      transition: none;
    }
  }

  @media (min-width: 1024px) {
    .scroll-menu-toggle {
      display: none !important;
    }
  }
</style>

<script>
  const btn = document.querySelector<HTMLButtonElement>('[data-mobile-toggle]');
  const scrollBtn = document.querySelector<HTMLButtonElement>('[data-scroll-menu-toggle]');
  const panel = document.querySelector<HTMLElement>('[data-mobile-panel]');
  const backdrop = document.querySelector<HTMLElement>('[data-mobile-backdrop]');
  const closeBtn = document.querySelector<HTMLButtonElement>('[data-mobile-close]');
  const links = document.querySelectorAll<HTMLAnchorElement>('[data-mobile-link]');
  const floatingThreshold = 260;

  function setButtonState(open: boolean) {
    [btn, scrollBtn].forEach((button) => {
      if (!button) return;
      button.setAttribute('aria-expanded', open ? 'true' : 'false');
      button.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
    });
  }

  function updateScrollMenu() {
    if (!scrollBtn) return;
    const show = window.scrollY > floatingThreshold && window.matchMedia('(max-width: 1023px)').matches;
    scrollBtn.hidden = false;
    scrollBtn.toggleAttribute('data-visible', show && !document.body.classList.contains('mobile-nav-open'));
  }

  function setOpen(open: boolean) {
    if (!btn || !panel || !backdrop) return;
    if (open) {
      panel.setAttribute('data-open', '');
      backdrop.setAttribute('data-open', '');
      panel.setAttribute('aria-hidden', 'false');
      panel.removeAttribute('inert');
      setButtonState(true);
      document.body.classList.add('mobile-nav-open');
      updateScrollMenu();
    } else {
      panel.removeAttribute('data-open');
      backdrop.removeAttribute('data-open');
      panel.setAttribute('aria-hidden', 'true');
      panel.setAttribute('inert', '');
      setButtonState(false);
      document.body.classList.remove('mobile-nav-open');
      updateScrollMenu();
    }
  }

  btn?.addEventListener('click', () => {
    const isOpen = btn.getAttribute('aria-expanded') === 'true';
    setOpen(!isOpen);
  });

  scrollBtn?.addEventListener('click', () => {
    const isOpen = scrollBtn.getAttribute('aria-expanded') === 'true';
    setOpen(!isOpen);
  });

  closeBtn?.addEventListener('click', () => setOpen(false));

  backdrop?.addEventListener('click', () => setOpen(false));

  // Close the menu when a link is tapped (same-page anchors still work).
  links.forEach((a) => a.addEventListener('click', () => setOpen(false)));

  // Esc closes.
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') setOpen(false);
  });

  // If the viewport becomes desktop-sized, reset state so nothing lingers.
  const mq = window.matchMedia('(min-width: 1024px)');
  mq.addEventListener('change', (e) => {
    if (e.matches) setOpen(false);
    updateScrollMenu();
  });

  window.addEventListener('scroll', updateScrollMenu, { passive: true });
  window.addEventListener('resize', updateScrollMenu);

  updateScrollMenu();
</script>
