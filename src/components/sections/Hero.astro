---
import Button from '@components/Button.astro';
import { withBase } from '@lib/paths';
---

<section class="relative overflow-hidden bg-cream">
  <div class="container-wide section grid items-center gap-6 py-8 md:grid-cols-12 md:gap-8 md:pb-10 md:pt-10 lg:pb-8">
    <div class="relative z-10 md:col-span-6 xl:col-span-5">
      <p class="hero-eyebrow font-script text-forest-ink/80">Fresh. Local. Sustainable.</p>

      <div class="hero-title-wrap mt-3 font-display font-medium leading-[1.02]">
        <h1 class="text-forest-ink">
          Fresh produce,<br />local flavour
        </h1>
      </div>

      <p class="mt-4 max-w-prose2 text-[0.92rem] leading-relaxed text-ink/80">
        Fruit, vegetables and pantry favourites from trusted Yorkshire growers
        and makers, served from our village shop in Idle.
      </p>

      <div class="hero-cta-group mt-5">
        <Button href="/our-produce" variant="primary" class="hero-cta-button">Shop our produce</Button>
        <Button href="/about" variant="outline" class="hero-cta-button">About us</Button>
      </div>
    </div>

    <div class="relative hidden md:col-span-6 md:block md:self-end xl:col-span-7">
      <div class="hero-bleed-right relative">
        <img
          src={withBase('/images/hero/hero-crate.webp')}
          alt="A wooden crate branded Idle Greengrocers overflowing with fresh seasonal produce - cabbage, leeks, potatoes, beetroot and carrots."
          width="1600"
          height="1200"
          loading="eager"
          fetchpriority="high"
          decoding="async"
          class="block aspect-[16/10] w-full object-contain object-right-bottom drop-shadow-[0_30px_45px_rgba(36,43,33,0.18)]"
        />
      </div>
    </div>
  </div>
</section>

<style>
  .hero-eyebrow {
    font-size: clamp(1.25rem, 3vw, 2.25rem);
  }

  .hero-title-wrap {
    font-size: clamp(2.4rem, 6.2vw, 4.8rem);
  }

  .hero-bleed-right {
    width: calc(100% + var(--section-pad));
    max-width: none;
    margin-right: calc(-1 * var(--section-pad));
  }

  .hero-cta-group {
    display: flex;
    flex-wrap: wrap;
    align-items: stretch;
    gap: 0.75rem;
    max-width: 100%;
  }

  .hero-cta-group :global(.hero-cta-button) {
    flex: 1 1 auto;
    min-width: 0;
    justify-content: center;
    padding-inline: 1rem;
    text-align: center;
  }

  @media (max-width: 359px) {
    .hero-cta-group {
      gap: 0.5rem;
    }

    .hero-cta-group :global(.hero-cta-button) {
      padding-inline: 0.875rem;
      letter-spacing: 0.16em;
    }
  }
</style>
