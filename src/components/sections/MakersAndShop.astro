---
import Button from '@components/Button.astro';
import { withBase } from '@lib/paths';
import { site } from '@lib/site';

const mapsQuery = encodeURIComponent(site.address.full);
const mapsUrl = `https://www.google.com/maps/search/?api=1&query=${mapsQuery}`;
---

<section class="grid md:grid-cols-2">
  <!-- Meet the Makers -->
  <div class="relative overflow-hidden bg-cream-400">
    <div class="section grid items-center gap-8 py-16 md:grid-cols-2 md:py-20">
      <div>
        <p class="eyebrow">Meet the Makers</p>
        <h2 class="mt-3 font-display text-3xl font-medium leading-tight text-forest-ink md:text-4xl">
          Supporting local<br />farmers &amp; makers
        </h2>
        <p class="mt-5 max-w-prose2 text-[0.92rem] leading-relaxed text-ink/80">
          We're proud to champion the brilliant people growing, baking and crafting
          across our region.
        </p>
        <div class="mt-6">
          <Button href="/local-makers" variant="outline">Discover our suppliers</Button>
        </div>
      </div>

      <!-- Polaroids: 2 across the top, 1 centered below overlapping -->
      <div class="relative mx-auto h-[360px] w-full max-w-sm md:h-[380px]">
        <!-- Top-left -->
        <div class="absolute left-0 top-0 w-36 -rotate-6 bg-cream-50 p-2 shadow-polaroid md:w-40">
          <img
            src={withBase('/images/makers/polaroid-cow.jpg')}
            alt="A brown-and-white Yorkshire dairy cow in a green pasture."
            width="320"
            height="400"
            loading="lazy"
            class="aspect-[4/5] w-full object-cover"
          />
        </div>
        <!-- Top-right (slightly overlaps top-left horizontally) -->
        <div class="absolute right-0 top-4 w-36 rotate-6 bg-cream-50 p-2 shadow-polaroid md:w-40">
          <img
            src={withBase('/images/makers/polaroid-preserves.jpg')}
            alt="Three small jars of homemade preserves with handwritten kraft labels."
            width="320"
            height="400"
            loading="lazy"
            class="aspect-[4/5] w-full object-cover"
          />
        </div>
        <!-- Bottom, centered, overlapping upward into the pair above -->
        <div class="absolute bottom-0 left-1/2 w-40 -translate-x-1/2 -rotate-3 bg-cream-50 p-2 shadow-polaroid md:w-44">
          <img
            src={withBase('/images/makers/polaroid-bread.jpg')}
            alt="Artisan sourdough boules on a dark wooden peel."
            width="320"
            height="400"
            loading="lazy"
            class="aspect-[4/5] w-full object-cover"
          />
        </div>
        <div class="absolute bottom-0 left-[calc(50%+5rem)] z-10 w-20 -translate-x-1/2 translate-y-1/2 md:left-[calc(50%+5.5rem)] md:w-24">
          <img
            src={withBase('/images/hero/yorkshire-logo.png')}
            alt="Idle Greengrocers Yorkshire logo"
            width="150"
            height="150"
            loading="lazy"
            decoding="async"
            class="h-auto w-full"
          />
        </div>
      </div>
    </div>
  </div>

  <!-- Visit our Shop -->
  <div class="green-texture relative grid overflow-hidden bg-forest-ink text-cream md:grid-cols-2">
    <!-- Copy -->
    <div class="section flex flex-col justify-center py-16 md:py-20">
      <p class="eyebrow" style="color:#D8A07A">Visit our Shop</p>
      <h2 class="mt-3 font-display text-3xl font-medium leading-tight text-cream md:text-4xl">
        Right in the heart<br />of Idle village
      </h2>
      <p class="mt-5 max-w-prose2 text-[0.92rem] leading-relaxed text-cream/80">
        Pop in and see us. We'd love to help you fill your basket.
      </p>

      <p class="mt-6 flex items-start gap-3 text-sm text-cream/90">
        <svg viewBox="0 0 24 24" class="mt-0.5 h-4 w-4 flex-none" fill="none" stroke="currentColor" stroke-width="1.4">
          <path d="M12 21s-7-7.5-7-12a7 7 0 1 1 14 0c0 4.5-7 12-7 12z" />
          <circle cx="12" cy="9" r="2.5" />
        </svg>
        <span>{site.address.full}</span>
      </p>

      <div class="mt-6">
        <Button href={mapsUrl} variant="outline-cream">Get directions</Button>
      </div>
    </div>

    <!-- Shopfront — fills the full height of this panel -->
    <div class="relative min-h-[420px] md:min-h-0">
      <img
        src={withBase('/images/shop/shopfront.png')}
        alt="The forest-green shopfront of Idle Greengrocers with crates of fresh produce outside."
        width="900"
        height="1400"
        loading="lazy"
        decoding="async"
        class="absolute inset-0 h-full w-full object-cover"
      />
    </div>
  </div>
</section>
