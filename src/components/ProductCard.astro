---
import { withBase } from '@lib/paths';

type Season = 'spring' | 'summer' | 'autumn' | 'winter';

type Props = {
  name: string;
  origin: string;
  price: number;
  unit: string;
  image: string;
  imageAlt: string;
  isLocal?: boolean;
  supplier?: string;
  seasons?: readonly Season[];
  tone?: 'cream' | 'dark';
  loading?: 'eager' | 'lazy';
  imageAspect?: 'portrait' | 'square';
};
const {
  name,
  origin,
  price,
  unit,
  image,
  imageAlt,
  isLocal = true,
  supplier,
  seasons = [],
  tone = 'cream',
  loading = 'lazy',
  imageAspect = 'portrait',
} = Astro.props;

const cardBg = tone === 'dark' ? 'bg-cream-50' : 'bg-white';
const aspectClass = imageAspect === 'square' ? 'aspect-square' : 'aspect-[4/5]';
const priceFormatted = new Intl.NumberFormat('en-GB', {
  style: 'currency',
  currency: 'GBP',
}).format(price);
const imageSrc = withBase(image);

/** Map a 0-indexed month to its UK meteorological season. */
function currentSeason(): Season {
  const m = new Date().getMonth();
  if (m >= 2 && m <= 4) return 'spring';
  if (m >= 5 && m <= 7) return 'summer';
  if (m >= 8 && m <= 10) return 'autumn';
  return 'winter';
}

const inSeasonNow = seasons.length > 0 && seasons.includes(currentSeason());
---

<article class={`group flex h-full flex-col overflow-hidden shadow-card ${cardBg}`}>
  <div class={`relative ${aspectClass} overflow-hidden bg-cream-300`}>
    <img
      src={imageSrc}
      alt={imageAlt}
      loading={loading}
      decoding="async"
      class="h-full w-full object-cover transition-transform duration-300 ease-out group-hover:scale-[1.03]"
      width="640"
      height="800"
    />
    <div class="absolute left-3 right-3 top-3 flex items-start justify-between gap-2">
      {inSeasonNow ? (
        <span class="inline-flex items-center gap-1 bg-terracotta/95 px-2 py-1 font-sans text-[0.58rem] font-semibold uppercase tracking-widest2 text-cream">
          <span class="inline-block h-1.5 w-1.5 rounded-full bg-cream" aria-hidden="true"></span>
          In season
        </span>
      ) : (
        <span aria-hidden="true"></span>
      )}
      {isLocal && (
        <span class="bg-cream-50/95 px-2 py-1 font-sans text-[0.58rem] font-semibold uppercase tracking-widest2 text-forest-ink">
          Local
        </span>
      )}
    </div>
  </div>
  <div class="flex flex-1 flex-col items-center gap-1 px-3 py-3 text-center">
    <h3 class="font-sans text-[0.78rem] font-semibold uppercase tracking-widest2 text-forest-ink">
      {name}
    </h3>
    <p class="font-sans text-[0.7rem] text-ink-muted">{origin}</p>
    {supplier && (
      <p class="font-script text-[0.92rem] leading-tight text-ink-muted">
        {supplier}
      </p>
    )}
    <p class="mt-2 font-sans text-[0.72rem] font-medium uppercase tracking-widest2 text-ink">
      {priceFormatted} / {unit}
    </p>
  </div>
</article>
