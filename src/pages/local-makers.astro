---
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import LeafDivider from '@components/LeafDivider.astro';
import { withBase } from '@lib/paths';

const makers = (await getCollection('makers')).sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout
  title="Local Makers"
  description="Meet the Yorkshire farmers, growers and artisan makers behind the produce on our shelves."
>
  <section class="bg-cream">
    <div class="container-wide section pb-10 pt-16 text-center md:pb-14 md:pt-20">
      <p class="eyebrow">Local Makers</p>
      <h1 class="mt-3 font-display text-4xl font-medium text-forest-ink md:text-6xl">
        The people<br />behind the produce
      </h1>
      <p class="mx-auto mt-5 max-w-2xl text-[0.95rem] leading-relaxed text-ink/80">
        Every shelf tells a story. These are the Yorkshire growers, bakers and makers whose
        work we're proud to stock.
      </p>
    </div>

    <div class="container-wide section pb-6">
      <LeafDivider tone="dark" />
    </div>

    <div class="container-wide section grid gap-10 pb-24 md:grid-cols-2">
      {makers.map(async (m) => {
        const { Content } = await m.render();
        return (
          <article class="group grid gap-6 md:grid-cols-5 md:gap-8">
            <div class="md:col-span-2">
              <img
                src={withBase(m.data.image)}
                alt={m.data.imageAlt}
                width="720"
                height="900"
                loading="lazy"
                class="aspect-[4/5] w-full object-cover shadow-card"
              />
            </div>
            <div class="md:col-span-3">
              <p class="font-sans text-[0.68rem] font-medium uppercase tracking-widest2 text-terracotta">
                {m.data.location}
              </p>
              <h2 class="mt-2 font-display text-2xl font-medium text-forest-ink md:text-3xl">
                {m.data.name}
              </h2>
              <p class="mt-1 font-sans text-sm text-ink-muted">{m.data.speciality}</p>
              <div class="mt-4 max-w-prose2 space-y-3 text-[0.95rem] leading-relaxed text-ink/80">
                <Content />
              </div>
              {m.data.website && (
                <a href={m.data.website} target="_blank" rel="noopener" class="mt-4 inline-block font-sans text-[0.72rem] font-medium uppercase tracking-widest2 text-forest underline underline-offset-4">
                  Visit website →
                </a>
              )}
            </div>
          </article>
        );
      })}
    </div>
  </section>
</BaseLayout>
