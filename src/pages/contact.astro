---
import BaseLayout from '@layouts/BaseLayout.astro';
import LeafDivider from '@components/LeafDivider.astro';
import Button from '@components/Button.astro';
import OpeningHours from '@components/OpeningHours.astro';
import { site } from '@lib/site';

const mapsQuery = encodeURIComponent(site.address.full);
const mapsUrl = `https://www.google.com/maps/search/?api=1&query=${mapsQuery}`;
// Google Maps' keyless embed endpoint — renders a simple place map in an
// iframe without requiring an API key. Lazy-loaded below.
const mapEmbedUrl = `https://www.google.com/maps?q=${mapsQuery}&output=embed`;

const waMessage = encodeURIComponent(`Hi ${site.name},`);
const waHref = `https://wa.me/${site.whatsapp.number.replace(/\D/g, '')}?text=${waMessage}`;
const telHref = `tel:${site.contact.phone.replace(/\s/g, '')}`;
const mailHref = `mailto:${site.contact.email}`;
---

<BaseLayout
  title="Contact"
  description={`Visit, call or email Idle Greengrocers at ${site.address.full}.`}
  includeLocalBusinessSchema={true}
>
  <section class="bg-cream">
    <div class="container-wide section pb-10 pt-16 text-center md:pb-14 md:pt-20">
      <p class="eyebrow">Contact</p>
      <h1 class="mt-3 font-display text-4xl font-medium text-forest-ink md:text-6xl">
        Say hello
      </h1>
      <p class="mx-auto mt-5 max-w-2xl text-[0.98rem] leading-relaxed text-ink/72">
        Drop into the shop, give us a ring, or send a note through the form and we will get back
        to you as soon as we can.
      </p>
    </div>

    <div class="container-wide section grid gap-8 pb-24 lg:grid-cols-[minmax(0,0.95fr)_minmax(0,1.05fr)] lg:gap-10">
      <div class="contact-panel contact-panel-soft">
        <LeafDivider tone="dark" label="Visit" />

        <!-- Preferred contact order for a small local shop: visit > WhatsApp
             (out-of-hours friendly) > call > email. -->
        <ol class="contact-methods">
          <li class="contact-method">
            <span class="contact-method__icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 21s-7-7.5-7-12a7 7 0 1 1 14 0c0 4.5-7 12-7 12z" />
                <circle cx="12" cy="9" r="2.5" />
              </svg>
            </span>
            <div>
              <p class="contact-method__label">Pop by the shop</p>
              <address class="contact-method__value">
                {site.address.line1}, {site.address.locality}, {site.address.postalCode}
              </address>
              <a href={mapsUrl} target="_blank" rel="noopener" class="contact-method__link">
                Open in Maps &rarr;
              </a>
            </div>
          </li>

          <li class="contact-method">
            <span class="contact-method__icon contact-method__icon--whatsapp" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 11.5a8.38 8.38 0 0 1-8.5 8.5 8.5 8.5 0 0 1-7.6-4.9L3 21l5.9-2.1A8.38 8.38 0 0 1 3 12.5 8.5 8.5 0 0 1 12.5 4a8.38 8.38 0 0 1 8.5 7.5" />
              </svg>
            </span>
            <div>
              <p class="contact-method__label">WhatsApp — the fastest way</p>
              <p class="contact-method__value">
                <a href={waHref} target="_blank" rel="noopener" class="contact-link">{site.whatsapp.display}</a>
              </p>
              <p class="contact-method__hint">Great for orders and collection queries.</p>
            </div>
          </li>

          <li class="contact-method">
            <span class="contact-method__icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
                <path d="M22 16.9v3a2 2 0 0 1-2.2 2 19.8 19.8 0 0 1-8.6-3.1 19.5 19.5 0 0 1-6-6A19.8 19.8 0 0 1 2.1 4.2 2 2 0 0 1 4.1 2h3a2 2 0 0 1 2 1.7c.1.9.3 1.8.6 2.7a2 2 0 0 1-.5 2.1L8 9.8a16 16 0 0 0 6 6l1.3-1.3a2 2 0 0 1 2.1-.5c.9.3 1.8.5 2.7.6a2 2 0 0 1 1.7 2" />
              </svg>
            </span>
            <div>
              <p class="contact-method__label">Call the shop</p>
              <p class="contact-method__value">
                <a href={telHref} class="contact-link">{site.contact.phoneDisplay}</a>
              </p>
              <p class="contact-method__hint">We answer during opening hours.</p>
            </div>
          </li>

          <li class="contact-method">
            <span class="contact-method__icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="5" width="18" height="14" rx="1" />
                <path d="M3 7l9 6 9-6" />
              </svg>
            </span>
            <div>
              <p class="contact-method__label">Email</p>
              <p class="contact-method__value">
                <a href={mailHref} class="contact-link">{site.contact.email}</a>
              </p>
            </div>
          </li>
        </ol>

        <div class="mt-6 flex flex-wrap gap-3">
          <Button href={waHref} variant="primary">Message on WhatsApp</Button>
          <Button href={mapsUrl} variant="outline">Open in Maps</Button>
        </div>

        <!-- Lazy-load the map; only fetched when the user scrolls to it. -->
        <div class="contact-map">
          <iframe
            title={`Map showing ${site.name} at ${site.address.full}`}
            src={mapEmbedUrl}
            width="100%"
            height="280"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            style="border:0; display:block;"
          ></iframe>
        </div>

        <OpeningHours hours={site.hours} />
      </div>

      <div class="contact-panel contact-panel-plain">
        <LeafDivider tone="dark" label="Send a message" />
        <h2 class="mt-6 font-display text-3xl font-medium text-forest-ink md:text-[2.15rem]">
          Ask about produce, orders or collection.
        </h2>
        <p class="mt-4 max-w-xl text-[0.95rem] leading-relaxed text-ink/72">
          If you are after something specific, let us know what you need and when you need it.
          We will point you in the right direction.
        </p>
        <!-- Netlify Forms: static form, submissions captured by Netlify -->
        <form
          name="contact"
          method="POST"
          action="/thank-you"
          data-netlify="true"
          netlify-honeypot="bot-field"
          class="mt-8 space-y-5"
        >
          <input type="hidden" name="form-name" value="contact" />
          <p class="hidden" aria-hidden="true">
            <label>Don't fill this out if you're human: <input name="bot-field" tabindex="-1" autocomplete="off" /></label>
          </p>

          <div>
            <label for="name" class="contact-label">
              Name
            </label>
            <input
              required
              id="name"
              name="name"
              type="text"
              autocomplete="name"
              class="contact-input"
            />
          </div>

          <div>
            <label for="email" class="contact-label">
              Email
            </label>
            <input
              required
              id="email"
              name="email"
              type="email"
              autocomplete="email"
              inputmode="email"
              class="contact-input"
            />
          </div>

          <div>
            <label for="topic" class="contact-label">
              What's this about?
            </label>
            <select id="topic" name="topic" class="contact-input contact-select">
              <option value="general">Something else (general enquiry)</option>
              <option value="order">Placing an order / collection</option>
              <option value="delivery">Local delivery</option>
              <option value="supplier">I'd like to supply you</option>
              <option value="wholesale">Wholesale / cafe &amp; restaurants</option>
              <option value="press">Press &amp; media</option>
            </select>
          </div>

          <div>
            <label for="message" class="contact-label">
              Message
            </label>
            <textarea
              required
              id="message"
              name="message"
              rows="5"
              autocomplete="off"
              class="contact-input min-h-[10rem] resize-y"
            ></textarea>
          </div>

          <div class="flex flex-wrap items-center gap-4 pt-2">
            <Button type="submit" variant="primary">Send message</Button>
            <p class="text-sm text-ink/60">We usually reply during shop opening hours.</p>
          </div>
        </form>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .contact-panel {
    min-width: 0;
    border: 1px solid rgba(31, 58, 40, 0.1);
    padding: 1.5rem;
  }

  .contact-panel-soft {
    background:
      radial-gradient(circle at top right, rgba(216, 160, 122, 0.12), transparent 38%),
      linear-gradient(180deg, rgba(251, 247, 238, 0.98), rgba(240, 226, 206, 0.7));
    box-shadow: 0 18px 36px -28px rgba(28, 26, 22, 0.3);
  }

  .contact-panel-plain {
    background: rgba(251, 247, 238, 0.76);
    box-shadow: 0 18px 36px -30px rgba(28, 26, 22, 0.22);
  }

  .contact-card {
    min-width: 0;
    border: 1px solid rgba(31, 58, 40, 0.1);
    background: rgba(251, 247, 238, 0.72);
    padding: 1rem;
  }

  /* Preferred-contact list */
  .contact-methods {
    list-style: none;
    margin: 1.5rem 0 0;
    padding: 0;
    display: grid;
    gap: 0.85rem;
  }

  .contact-method {
    display: flex;
    align-items: flex-start;
    gap: 0.85rem;
    min-width: 0;
    border: 1px solid rgba(31, 58, 40, 0.08);
    background: rgba(251, 247, 238, 0.6);
    padding: 0.85rem 1rem;
  }

  .contact-method__icon {
    flex: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 2.25rem;
    width: 2.25rem;
    border-radius: 999px;
    background: rgba(37, 54, 40, 0.08);
    color: #253628;
  }

  .contact-method__icon--whatsapp {
    background: rgba(47, 107, 69, 0.14);
    color: #2f6b45;
  }

  .contact-method__icon svg {
    height: 1.15rem;
    width: 1.15rem;
  }

  .contact-method__label {
    font-family: Inter, system-ui, sans-serif;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #0e2419;
  }

  .contact-method__value {
    margin-top: 0.3rem;
    font-size: 0.95rem;
    line-height: 1.4;
    color: rgba(28, 26, 22, 0.82);
    font-style: normal;
    overflow-wrap: anywhere;
  }

  .contact-method__hint {
    margin-top: 0.25rem;
    font-size: 0.82rem;
    line-height: 1.45;
    color: rgba(28, 26, 22, 0.58);
  }

  .contact-method__link {
    display: inline-block;
    margin-top: 0.25rem;
    font-size: 0.82rem;
    font-weight: 500;
    color: #253628;
    text-decoration: underline;
    text-underline-offset: 0.22rem;
  }

  .contact-method__link:hover,
  .contact-method__link:focus-visible {
    color: #0e2419;
  }

  /* Embedded map */
  .contact-map {
    margin-top: 1.5rem;
    overflow: hidden;
    border: 1px solid rgba(31, 58, 40, 0.1);
    background: rgba(14, 36, 25, 0.04);
  }

  /* Native select styled to match .contact-input */
  .contact-select {
    appearance: none;
    background-image:
      linear-gradient(45deg, transparent 50%, rgba(14, 36, 25, 0.65) 50%),
      linear-gradient(-45deg, transparent 50%, rgba(14, 36, 25, 0.65) 50%);
    background-position:
      calc(100% - 1.1rem) 55%,
      calc(100% - 0.75rem) 55%;
    background-size: 0.35rem 0.35rem, 0.35rem 0.35rem;
    background-repeat: no-repeat;
    padding-right: 2.25rem;
    cursor: pointer;
  }

  .contact-card-label,
  .contact-label {
    font-family: Inter, system-ui, sans-serif;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #0e2419;
  }

  .contact-link {
    overflow-wrap: anywhere;
    text-decoration: underline;
    text-underline-offset: 0.25rem;
    transition: color 150ms ease;
  }

  .contact-link:hover,
  .contact-link:focus-visible {
    color: #253628;
  }

  .contact-input {
    display: block;
    margin-top: 0.45rem;
    width: 100%;
    min-width: 0;
    border: 1px solid rgba(31, 58, 40, 0.2);
    background: rgba(255, 251, 245, 0.95);
    box-sizing: border-box;
    padding: 0.85rem 0.95rem;
    font-size: 0.95rem;
    color: #1c1a16;
    transition: border-color 150ms ease, box-shadow 150ms ease, background-color 150ms ease;
  }

  .contact-input:hover {
    border-color: rgba(31, 58, 40, 0.32);
  }

  .contact-input:focus {
    border-color: rgba(37, 54, 40, 0.62);
    box-shadow: 0 0 0 4px rgba(37, 54, 40, 0.08);
    background: #fffdf9;
    outline: none;
  }

  @media (min-width: 768px) {
    .contact-panel {
      padding: 2rem;
    }
  }

  @media (max-width: 520px) {
    .contact-panel {
      padding: 1.2rem;
    }
  }
</style>
