---
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import LeafDivider from '@components/LeafDivider.astro';
import ProductCard from '@components/ProductCard.astro';

const products = (await getCollection('products')).sort((a, b) => a.data.order - b.data.order);

const categories = [
  { id: 'all', label: 'All' },
  { id: 'fruit', label: 'Fruit' },
  { id: 'vegetables', label: 'Vegetables' },
  { id: 'dairy-eggs', label: 'Dairy & Eggs' },
  { id: 'bakery', label: 'Bakery' },
  { id: 'preserves', label: 'Preserves & Pantry' },
] as const;
---

<BaseLayout
  title="Our Produce"
  description="Browse fresh fruit, vegetables, dairy, eggs, bakery and local preserves available at Idle Greengrocers."
>
  <section class="bg-cream">
    <div class="container-wide section pb-10 pt-16 text-center md:pb-14 md:pt-20">
      <p class="eyebrow">Our Produce</p>
      <h1 class="mt-3 font-display text-4xl font-medium text-forest-ink md:text-6xl">
        Fresh today
      </h1>
      <p class="mx-auto mt-5 max-w-2xl text-[0.95rem] leading-relaxed text-ink/80">
        Our shelves change with the seasons. Here's what's arriving from Yorkshire's best
        growers and makers this week.
      </p>
    </div>

    <div class="container-wide section pb-4">
      <LeafDivider tone="dark" />
    </div>

    <!-- Category filter. Buttons act as a toggle-group; active state is
         reflected via aria-pressed so assistive tech announces it. -->
    <div
      class="container-wide section flex flex-wrap items-center justify-center gap-2 pb-10"
      role="group"
      aria-label="Filter produce by category"
    >
      {categories.map((c) => (
        <button
          type="button"
          data-filter={c.id}
          class="btn-outline border-forest/40 px-4 py-2 text-[0.68rem] aria-pressed:bg-forest aria-pressed:text-cream"
          aria-pressed={c.id === 'all' ? 'true' : 'false'}
        >
          {c.label}
        </button>
      ))}
    </div>

    <div
      class="container-wide section grid grid-cols-2 gap-5 pb-6 sm:grid-cols-3 lg:grid-cols-4"
      data-product-grid
      aria-live="polite"
    >
      {products.map((p) => (
        <div data-category={p.data.category}>
          <ProductCard
            name={p.data.name}
            origin={p.data.origin}
            price={p.data.price}
            unit={p.data.unit}
            image={p.data.image}
            imageAlt={p.data.imageAlt}
            isLocal={p.data.isLocal}
          />
        </div>
      ))}
    </div>

    <p
      class="container-wide section hidden pb-24 text-center text-[0.95rem] text-ink/70"
      data-empty-state
      role="status"
    >
      Nothing in that category right now — try <button type="button" class="underline underline-offset-4 hover:text-ink" data-reset>All</button> to see everything we have in today.
    </p>
    <div class="container-wide section pb-24" data-grid-spacer></div>
  </section>

  <script>
    const buttons = document.querySelectorAll<HTMLButtonElement>('[data-filter]');
    const items = document.querySelectorAll<HTMLDivElement>('[data-category]');
    const emptyState = document.querySelector<HTMLElement>('[data-empty-state]');
    const spacer = document.querySelector<HTMLElement>('[data-grid-spacer]');
    const resetBtn = document.querySelector<HTMLButtonElement>('[data-reset]');
    const validFilters = new Set(Array.from(buttons, (b) => b.dataset.filter));

    function applyFilter(target: string, { updateUrl = true } = {}) {
      if (!validFilters.has(target)) target = 'all';

      buttons.forEach((b) =>
        b.setAttribute('aria-pressed', b.dataset.filter === target ? 'true' : 'false'),
      );

      let visible = 0;
      items.forEach((it) => {
        const match = target === 'all' || it.dataset.category === target;
        it.toggleAttribute('hidden', !match);
        if (match) visible += 1;
      });

      if (emptyState) emptyState.toggleAttribute('hidden', visible !== 0);
      if (spacer) spacer.toggleAttribute('hidden', visible === 0);

      if (updateUrl) {
        const url = new URL(window.location.href);
        if (target === 'all') url.searchParams.delete('category');
        else url.searchParams.set('category', target);
        window.history.replaceState({}, '', url);
      }
    }

    buttons.forEach((btn) =>
      btn.addEventListener('click', () => applyFilter(btn.dataset.filter ?? 'all')),
    );
    resetBtn?.addEventListener('click', () => applyFilter('all'));

    // Hydrate from ?category= on load so links/bookmarks are shareable.
    const initial = new URLSearchParams(window.location.search).get('category') ?? 'all';
    applyFilter(initial, { updateUrl: false });

    // Support back/forward navigation between filter states.
    window.addEventListener('popstate', () => {
      const current = new URLSearchParams(window.location.search).get('category') ?? 'all';
      applyFilter(current, { updateUrl: false });
    });
  </script>
</BaseLayout>
