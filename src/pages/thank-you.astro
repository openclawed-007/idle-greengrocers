---
import BaseLayout from '@layouts/BaseLayout.astro';
import Button from '@components/Button.astro';
---

<BaseLayout
  title="Message sent"
  description="Thanks for getting in touch — we'll reply during shop hours."
  noIndex={true}
>
  <section class="bg-cream">
    <div class="container-wide section flex flex-col items-center gap-6 py-24 text-center md:py-32">
      <p class="eyebrow">Message sent</p>
      <h1 class="font-display text-5xl font-medium text-forest-ink md:text-6xl">
        Thanks for writing in.
      </h1>
      <p class="max-w-prose2 text-[0.95rem] leading-relaxed text-ink/80">
        We've got your note and will reply during shop hours. In the meantime,
        have a browse of what's in today.
      </p>
      <div class="flex flex-wrap justify-center gap-3">
        <Button href="/our-produce" variant="primary">Browse produce</Button>
        <Button href="/" variant="outline">Back to home</Button>
      </div>
    </div>
  </section>
</BaseLayout>
